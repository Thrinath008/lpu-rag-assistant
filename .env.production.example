# ============================================================
# LPU RAG Assistant - Production Environment Configuration
# ============================================================

# API Configuration
PROJECT_NAME="LPU Knowledge Assistant"
VERSION="2.0.0"
API_V1_STR="/api/v1"

# LLM & Embeddings
GROQ_API_KEY="your-groq-api-key-here"
GEMINI_API_KEY=""

# Security
SECRET_KEY="your-secret-key-2026-change-in-production-min-32-chars"
API_KEY="lpu-rag-api-key-production"
ADMIN_KEY="lpu-admin-master-key-production"

# CORS & Host Configuration
ALLOWED_HOSTS="localhost,127.0.0.1,yourdomain.com"
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,https://yourdomain.com"

# Database
DATABASE_URL="sqlite:///./auth.db"

# Logging
LOG_LEVEL="INFO"

# Frontend
NEXT_PUBLIC_API_URL="http://127.0.0.1:8000/api"
NEXT_PUBLIC_APP_NAME="LPU Knowledge Assistant"
